# =============================================================================
# APPLICATION ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your actual values
# =============================================================================
# This file is tracked in git. For sensitive data, use the .env file (ignored).
# =============================================================================

# =============================================================================
# 1. ENVIRONMENT SETUP
# =============================================================================
CI_ENVIRONMENT = development
# Options: development, testing, production

# =============================================================================
# 2. DATABASE CONFIGURATION
# =============================================================================
DB_HOST = localhost
DB_USER = root
DB_PASSWORD = your_password_here
DB_NAME = rekomendasi_wisata
DB_PORT = 3306
DB_DRIVER = mysqli
DB_DEBUG = 1

# =============================================================================
# 3. APPLICATION CONFIGURATION
# =============================================================================
APP_URL = http://localhost
APP_TITLE = Rekomendasi Wisata Yogyakarta
APP_LOCALE = id

# =============================================================================
# 4. SESSION CONFIGURATION
# =============================================================================
SESSION_DRIVER = files
SESSION_LIFETIME = 3600
SESSION_COOKIE_NAME = ci_session

# =============================================================================
# 5. AUTHENTICATION
# =============================================================================
# OAuth (Google)
GOOGLE_CLIENT_ID = your_google_client_id_here
GOOGLE_CLIENT_SECRET = your_google_client_secret_here
GOOGLE_REDIRECT_URL = http://localhost/auth/google_callback

# Session secret key
SESSION_ENCRYPTION_KEY = your_encryption_key_here

# =============================================================================
# 6. PYTHON MICROSERVICE (RECOMMENDATION ENGINE)
# =============================================================================
PYTHON_SERVICE_URL = http://localhost:5000
PYTHON_SERVICE_PORT = 5000

# Recommendation algorithm parameters
RECOMMENDATION_K = 5
RECOMMENDATION_N_RESULTS = 10
RECOMMENDATION_ALPHA = 0.6
# alpha = weight for collaborative filtering (0-1)
# 1.0 = only collaborative filtering
# 0.0 = only content-based filtering
# 0.6 = 60% collaborative + 40% content-based (recommended)

# =============================================================================
# 7. EMAIL CONFIGURATION (if sending emails)
# =============================================================================
EMAIL_PROTOCOL = smtp
EMAIL_SMTP_HOST = smtp.gmail.com
EMAIL_SMTP_PORT = 587
EMAIL_SMTP_USER = your_email@gmail.com
EMAIL_SMTP_PASSWORD = your_email_password
EMAIL_FROM = noreply@rekomendasiwisata.local
EMAIL_FROM_NAME = Rekomendasi Wisata

# =============================================================================
# 8. LOGGING
# =============================================================================
LOG_LEVEL = 4
# 0 = Emergency
# 1 = Alert
# 2 = Critical
# 3 = Error
# 4 = Warning
# 5 = Notice
# 6 = Informational
# 7 = Debug

# =============================================================================
# 9. SECURITY
# =============================================================================
ENABLE_CSRF_PROTECTION = TRUE
CSRF_TOKEN_NAME = csrf_test_name
CSRF_COOKIE_NAME = csrf_cookie_name

# API Rate Limiting
RATE_LIMIT_ENABLED = TRUE
RATE_LIMIT_PER_MINUTE = 60

# =============================================================================
# 10. FILE UPLOADS
# =============================================================================
MAX_UPLOAD_SIZE = 5242880
# Size in bytes (5MB default)

ALLOWED_UPLOAD_TYPES = jpg,jpeg,png,gif,pdf,doc,docx
UPLOAD_PATH = /uploads/

# =============================================================================
# 11. CACHING
# =============================================================================
CACHE_DRIVER = file
# Options: file, memcached, redis, database
# Cache recommendation results for better performance
CACHE_EXPIRE_RECOMMENDATION = 86400
# Cache expiration in seconds (86400 = 24 hours)

# =============================================================================
# 12. DEBUGGING & MONITORING
# =============================================================================
DEBUG_MODE = TRUE
DISPLAY_ERRORS = TRUE
# Set to FALSE on production

# Performance monitoring
ENABLE_PROFILING = FALSE
ENABLE_QUERY_LOG = TRUE

# =============================================================================
# 13. EXTERNAL SERVICES
# =============================================================================
# Analytics (optional)
GOOGLE_ANALYTICS_ID = 

# Sentry (error tracking) - optional
SENTRY_DSN = 

# =============================================================================
# 14. FEATURE FLAGS
# =============================================================================
# Enable/disable features
FEATURE_GOOGLE_LOGIN = TRUE
FEATURE_RECOMMENDATIONS = TRUE
FEATURE_RATINGS = TRUE
FEATURE_FAVORITES = TRUE
FEATURE_ADMIN_PANEL = TRUE

# =============================================================================
# NOTES:
# =============================================================================
# - DO NOT commit the .env file to git (add to .gitignore)
# - DO commit this .env.example file as a template
# - On production, update values carefully
# - Keep sensitive data (passwords, API keys) out of version control
# - Use environment variables instead of hardcoded values
